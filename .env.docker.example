# Registry
REGISTRY_PREFIX=docker.io/
BACKEND_IMAGE=library/python
CLIENT_IMAGE=library/node

# Backend
MOOD_WEATHER_BACKEND_PORT=42001
MOOD_WEATHER_API_KEY=dev-secret-key
MOOD_WEATHER_DB_HOST=postgres
MOOD_WEATHER_DB_PORT=5432
MOOD_WEATHER_DB_NAME=moodweather
MOOD_WEATHER_DB_USER=mooduser
MOOD_WEATHER_DB_PASSWORD=moodpass

# Database
POSTGRES_PORT=5432
POSTGRES_DB=moodweather
POSTGRES_USER=mooduser
POSTGRES_PASSWORD=moodpass
PGADMIN_PORT=42003
PGADMIN_DEFAULT_EMAIL=admin@moodweather.dev
PGADMIN_DEFAULT_PASSWORD=admin

# Client Web React
MOOD_WEATHER_CLIENT_PORT=5173
VITE_API_TARGET=http://backend:42001

# Caddy
CADDY_PORT=42002

# Qwen Code API (submodule)
QWEN_CODE_API_PORT=42005
QWEN_CODE_API_KEY=qwen-dev-key
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_MODEL=qwen2.5:7b

# Constants
MOOD_WEATHER_VERSION=0.1.0
